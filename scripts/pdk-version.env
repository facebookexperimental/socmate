#
# Single source of truth for the SkyWater Sky130 PDK pin used by socmate.
# The Dockerfile, scripts/install_toolchain.sh and CI all read this file
# so a PDK bump only needs to land in one place.
#
# Usage (bash):
#   source scripts/pdk-version.env
#   volare enable --pdk sky130 --pdk-root "$PDK_ROOT" "$SKY130_PDK_COMMIT"
#
# To bump: run `volare ls-remote --pdk sky130` and replace the hash below.

SKY130_PDK_COMMIT=c6d73a35f524070e85faff4a6a9eef49553ebc2b
