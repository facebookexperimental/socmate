# socmate ASIC Orchestrator Environment Variables
# ================================================
# Copy this file to .env and fill in your values.

# Anthropic API key. Used by the Claude CLI (`claude`) which the
# orchestrator shells out to for every LLM call. Either set this here
# or run `claude login` once interactively before starting the pipeline.
ANTHROPIC_API_KEY=

# Override the default model used by every agent. Accepts either a short
# name (opus-4.6, opus-4.5, sonnet-4.5, sonnet-4, haiku-3.5) or any full
# Claude CLI model ID. Empty/unset falls back to DEFAULT_MODEL in
# orchestrator/langchain/agents/cursor_llm.py.
# SOCMATE_MODEL=opus-4.5

# Override the path to the claude CLI binary if it isn't on $PATH.
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Optional: override the config file path
# SOCMATE_CONFIG=/path/to/config.yaml

# Optional: PDK root for Sky130 standard cells
# PDK_ROOT=/path/to/pdk
