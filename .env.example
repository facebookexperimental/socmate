# socmate ASIC Orchestrator Environment Variables
# ================================================
# Copy this file to .env and fill in your values.

# Anthropic API key. Used by the Claude CLI (`claude`) which the
# orchestrator shells out to for every LLM call. Either set this here
# or run `claude auth login` once interactively before starting the pipeline.
#
# Alternative for headless / CI: a long-lived OAuth token from
# `claude setup-token`, exported as CLAUDE_CODE_OAUTH_TOKEN. The
# Docker entrypoint (scripts/runpod_entrypoint.sh) accepts either.
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# Override the default model used by every agent. Accepts either a short
# name (opus-4.6, opus-4.5, sonnet-4.5, sonnet-4, haiku-3.5) or any full
# Claude CLI model ID. Empty/unset falls back to DEFAULT_MODEL in
# orchestrator/langchain/agents/socmate_llm.py.
# SOCMATE_MODEL=opus-4.5

# Override the path to the claude CLI binary if it isn't on $PATH.
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Optional: use Codex CLI instead of Claude CLI for LLM calls.
# Defaults to gpt-5.5 for top-level agents when SOCMATE_LLM_PROVIDER=codex.
# SOCMATE_LLM_PROVIDER=codex
# SOCMATE_CODEX_MODEL=gpt-5.5
# CODEX_CLI_PATH=/usr/local/bin/codex
# SOCMATE_CODEX_SANDBOX=workspace-write

# Optional: override the config file path
# SOCMATE_CONFIG=/path/to/config.yaml

# Optional: PDK root for Sky130 standard cells
# PDK_ROOT=/path/to/pdk
