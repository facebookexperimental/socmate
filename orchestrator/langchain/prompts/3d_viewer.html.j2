<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ design_name }} — 3D GDS Layout</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: #0f0e1a;
  color: #e2e8f0;
  overflow: hidden;
  height: 100vh;
}

header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 20;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.6rem 1.2rem;
  background: rgba(30, 27, 75, 0.92);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(99, 102, 241, 0.25);
}

header h1 {
  font-size: 1rem; font-weight: 600;
  color: #a5b4fc;
}

header .stats {
  font-size: 0.78rem; color: #94a3b8;
}

header a {
  font-size: 0.82rem; color: #818cf8;
  text-decoration: none; padding: 0.35rem 0.8rem;
  border: 1px solid rgba(129,140,248,0.3); border-radius: 6px;
  transition: background 0.2s;
}
header a:hover { background: rgba(129,140,248,0.15); }

#sidebar {
  position: fixed; top: 44px; left: 0; bottom: 0; z-index: 10;
  width: 190px; padding: 0.8rem 0;
  background: rgba(30, 41, 59, 0.95);
  border-right: 1px solid rgba(71, 85, 105, 0.5);
  overflow-y: auto;
}

#sidebar h3 {
  font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
  color: #64748b; padding: 0.4rem 0.9rem 0.3rem; margin-top: 0.5rem;
}

.layer-toggle {
  display: flex; align-items: center; gap: 0.4rem;
  padding: 0.25rem 0.9rem; cursor: pointer;
  transition: background 0.15s;
}
.layer-toggle:hover { background: rgba(51, 65, 85, 0.6); }

.layer-toggle input[type="checkbox"] {
  accent-color: #818cf8; width: 14px; height: 14px; cursor: pointer;
}

.swatch {
  width: 12px; height: 12px; border-radius: 2px;
  border: 1px solid rgba(255,255,255,0.15); flex-shrink: 0;
}

.layer-toggle label {
  font-size: 0.78rem; color: #cbd5e1; cursor: pointer;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

.layer-toggle .count {
  font-size: 0.65rem; color: #64748b; margin-left: auto; flex-shrink: 0;
}

.controls-help {
  padding: 0.4rem 0.9rem; font-size: 0.68rem; color: #475569;
  line-height: 1.6;
}

.controls-help kbd {
  display: inline-block; padding: 0.05rem 0.3rem;
  border: 1px solid #475569; border-radius: 3px;
  font-family: monospace; font-size: 0.68rem; color: #94a3b8;
  background: rgba(15,14,26,0.5);
}

#viewer {
  position: fixed; top: 44px; left: 190px; right: 0; bottom: 0;
}

#loading {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 100;
  display: flex; align-items: center; justify-content: center;
  background: #0f0e1a;
  transition: opacity 0.5s;
}
#loading.done { opacity: 0; pointer-events: none; }

#loading .spinner {
  width: 40px; height: 40px;
  border: 3px solid rgba(129,140,248,0.2);
  border-top-color: #818cf8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

#loading p { margin-top: 1rem; color: #94a3b8; font-size: 0.85rem; }

.loading-wrap { text-align: center; }

@media (max-width: 640px) {
  #sidebar { display: none; }
  #viewer { left: 0; }
}
</style>
</head>
<body>

<header>
  <h1>{{ design_name }} — 3D GDS Layout</h1>
  <span class="stats">{{ total_polygons | int }} polygons &middot; {{ glb_size_mb }} MB</span>
  <a href="dashboard.html">Dashboard</a>
</header>

<aside id="sidebar">
  <h3>Layers</h3>
  <div id="layer-panel"></div>
  <h3>Controls</h3>
  <div class="controls-help">
    <kbd>LMB</kbd> Rotate<br>
    <kbd>RMB</kbd> Pan<br>
    <kbd>Scroll</kbd> Zoom<br>
    <kbd>1</kbd> Toggle fill/tap cells<br>
    <kbd>R</kbd> Reset camera
  </div>
</aside>

<div id="viewer"></div>

<div id="loading">
  <div class="loading-wrap">
    <div class="spinner"></div>
    <p>Loading 3D layout&hellip;</p>
  </div>
</div>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.161.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.161.0/examples/jsm/"
  }
}
</script>

<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

const LAYER_INFO = {{ layer_info }};
const GLTF_B64 = '{{ gltf_base64 }}';

const container = document.getElementById('viewer');
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x0f0e1a);

const camera = new THREE.PerspectiveCamera(
  45, container.clientWidth / container.clientHeight, 0.01, 500,
);

const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(container.clientWidth, container.clientHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
container.appendChild(renderer.domElement);

const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.dampingFactor = 0.08;

scene.add(new THREE.AmbientLight(0xffffff, 0.7));
const dir = new THREE.DirectionalLight(0xffffff, 0.9);
dir.position.set(5, 12, 8);
scene.add(dir);

let initialCamPos = new THREE.Vector3();
let initialTarget = new THREE.Vector3();

const binary = Uint8Array.from(atob(GLTF_B64), c => c.charCodeAt(0));
const blob = new Blob([binary], { type: 'model/gltf-binary' });
const url = URL.createObjectURL(blob);

new GLTFLoader().load(url, (gltf) => {
  scene.add(gltf.scene);
  URL.revokeObjectURL(url);

  gltf.scene.traverse((child) => {
    if (child.isMesh) {
      child.material.flatShading = true;
      child.geometry.computeVertexNormals();
      child.material.needsUpdate = true;
    }
  });

  const box = new THREE.Box3().setFromObject(gltf.scene);
  const center = box.getCenter(new THREE.Vector3());
  const size = box.getSize(new THREE.Vector3());
  const maxDim = Math.max(size.x, size.y, size.z);

  controls.target.copy(center);
  camera.position.set(
    center.x + maxDim * 0.7,
    center.y + maxDim * 1.1,
    center.z + maxDim * 0.7,
  );
  camera.lookAt(center);
  controls.update();

  initialCamPos.copy(camera.position);
  initialTarget.copy(controls.target);

  buildLayerUI(gltf.scene);

  document.getElementById('loading').classList.add('done');
});

function buildLayerUI(model) {
  const panel = document.getElementById('layer-panel');

  for (const info of LAYER_INFO) {
    const node = model.getObjectByName(info.name);
    if (!node) continue;

    const div = document.createElement('div');
    div.className = 'layer-toggle';

    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.checked = true;
    cb.id = 'layer-' + info.name;
    cb.addEventListener('change', () => { node.visible = cb.checked; });

    const sw = document.createElement('span');
    sw.className = 'swatch';
    const [r, g, b] = info.color;
    sw.style.background = `rgb(${r*255|0},${g*255|0},${b*255|0})`;

    const lbl = document.createElement('label');
    lbl.htmlFor = cb.id;
    lbl.textContent = info.name;

    const cnt = document.createElement('span');
    cnt.className = 'count';
    cnt.textContent = info.count >= 1000
      ? (info.count / 1000).toFixed(1) + 'k'
      : String(info.count);

    div.append(cb, sw, lbl, cnt);
    panel.append(div);
  }
}

window.addEventListener('keydown', (e) => {
  if (e.key === '1') {
    const names = ['tap', 'nwell', 'diff'];
    for (const n of names) {
      const cb = document.getElementById('layer-' + n);
      if (cb) { cb.checked = !cb.checked; cb.dispatchEvent(new Event('change')); }
    }
  }
  if (e.key === 'r' || e.key === 'R') {
    camera.position.copy(initialCamPos);
    controls.target.copy(initialTarget);
    controls.update();
  }
});

window.addEventListener('resize', () => {
  camera.aspect = container.clientWidth / container.clientHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(container.clientWidth, container.clientHeight);
});

(function animate() {
  requestAnimationFrame(animate);
  controls.update();
  renderer.render(scene, camera);
})();
</script>
</body>
</html>
