{
  "name": "socmate-workflow-editor",
  "displayName": "SoCMate",
  "description": "Visual LangGraph workflow editor for the socmate ASIC pipeline",
  "version": "0.2.0",
  "publisher": "socmate",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:socmate.openWorkflowEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "socmate.openWorkflowEditor",
        "title": "socmate: Open Workflow Editor"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "socmate-workflow",
          "title": "socmate Workflow",
          "icon": "$(circuit-board)"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node && esbuild src/webview/App.jsx --bundle --outfile=dist/webview.js --format=esm --jsx=automatic --loader:.jsx=jsx --loader:.svg=dataurl",
    "watch": "npm run build -- --watch",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/vscode": "^1.85.0",
    "babel-jest": "^30.2.0",
    "esbuild": "^0.20.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "elkjs": "^0.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "reactflow": "^11.11.4"
  }
}
